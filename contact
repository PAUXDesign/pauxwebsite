<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" href="/Public/Images/icon.png" type="image/png">
<title>Contact — Paux Design</title>
<link href="https://fonts.googleapis.com/css2?family=Merriweather:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&family=Manrope:wght@300;400;500;600;700&family=Hanken+Grotesk:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/styles.css">
<style>
.contact-page {
  min-height: 100vh;
  padding: 132px 20px 72px;
  background: transparent;
}
.contact-wrap {
  max-width: 820px;
  margin: 0 auto;
}
.contact-card {
  background: #ffffff;
  border: 1px solid var(--border);
  border-radius: 24px;
  box-shadow: 0 16px 40px rgba(190,195,230,0.55);
  padding: 42px;
  position: relative;
  isolation: isolate;
}
.contact-card::before {
  content: '';
  position: absolute;
  inset: 10px;
  border-radius: 16px;
  background: rgba(255, 255, 255, 0.62);
  border: 1px solid rgba(38, 30, 72, 0.05);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  box-shadow: 0 8px 20px rgba(38, 30, 72, 0.08);
  z-index: 0;
}
.contact-card > * {
  position: relative;
  z-index: 1;
}
.contact-kicker {
  font-family: var(--font-meta);
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.11em;
  color: var(--accent);
  margin-bottom: 12px;
}
.contact-title {
  font-family: var(--font-serif);
  font-size: clamp(28px, 4vw, 42px);
  line-height: 1.15;
  color: var(--dark);
  margin-bottom: 12px;
}
.contact-sub {
  color: var(--mid);
  font-size: 14px;
  line-height: 1.7;
  margin-bottom: 28px;
}
.contact-form {
  display: grid;
  gap: 16px;
}
.contact-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(260px, 1fr));
  gap: 16px;
}
.contact-field {
  min-width: 0;
}
.contact-field label {
  display: block;
  font-family: var(--font-meta);
  font-size: 11px;
  color: var(--light);
  margin-bottom: 6px;
  letter-spacing: 0.04em;
}
.contact-field input,
.contact-field select,
.contact-field textarea {
  display: block;
  box-sizing: border-box;
  min-width: 0;
  max-width: 100%;
  width: 100%;
  border: 1px solid var(--border2);
  border-radius: 12px;
  background: #fff;
  color: var(--dark);
  font-family: var(--font-sans);
  font-size: 14px;
  padding: 12px 14px;
  outline: none;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}
.contact-field input:focus,
.contact-field select:focus,
.contact-field textarea:focus {
  border-color: rgba(112,89,220,0.45);
  box-shadow: 0 0 0 3px rgba(112,89,220,0.12);
}
.contact-field textarea {
  min-height: 140px;
  resize: vertical;
}
.contact-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12px;
  margin-top: 8px;
}
.contact-actions .btn {
  width: auto !important;
}
.contact-error {
  display: none;
  border: 1px solid rgba(220, 38, 38, 0.25);
  background: rgba(220, 38, 38, 0.08);
  color: #8f1d1d;
  font-size: 12px;
  line-height: 1.5;
  border-radius: 10px;
  padding: 10px 12px;
}
.contact-error.show {
  display: block;
}
.contact-recaptcha-note {
  font-size: 12px;
  color: var(--light);
  line-height: 1.5;
  margin: 0;
}
@media (max-width: 800px) {
  .contact-card { padding: 24px; border-radius: 18px; }
  .contact-card::before { inset: 8px; border-radius: 12px; }
  .contact-grid { grid-template-columns: 1fr; }
  .contact-actions { justify-content: flex-end; }
}
</style>
</head>
<body class="page-grid-bg">
<nav>
  <div class="nav-inner" id="site-nav">
    <div class="nav-brand">
      <a href="/"><img class="nav-brand-logo" src="/Public/Images/logo-name.png" alt="Paux Design"></a>
    </div>
    <ul class="nav-links" aria-label="Primary">
      <li><a href="/#about">About</a></li>
      <li><a href="/#services">Services</a></li>
      <li><a href="/work/">Work</a></li>
      <li><a href="/contact/">Contact</a></li>
    </ul>
    <div class="nav-cta">
      <a href="/contact/" class="btn btn-dark nav-cta-btn" style="padding:12px 18px;">Let's talk</a>
      <button type="button" class="nav-hamburger" id="navHamburger" onclick="toggleMobileNav()" aria-label="Open menu" aria-expanded="false" aria-controls="navMobileOverlay">
        <span class="nav-hamburger-bars" aria-hidden="true"><span></span><span></span><span></span></span>
      </button>
    </div>
  </div>
</nav>

<div class="nav-mobile-overlay" id="navMobileOverlay">
  <a href="/#about" onclick="closeMobileNav()">About</a>
  <a href="/#services" onclick="closeMobileNav()">Services</a>
  <a href="/work/" onclick="closeMobileNav()">Work</a>
  <a href="/contact/" onclick="closeMobileNav()">Contact</a>
  <div class="nav-mobile-divider"></div>
  <a href="/contact/" onclick="closeMobileNav()" class="btn btn-dark nav-mobile-cta">Let's talk</a>
</div>

<main class="contact-page">
  <div class="contact-wrap">
    <div class="contact-card">
      <div class="contact-kicker">Contact</div>
      <h1 class="contact-title">Tell me about your project</h1>
      <p class="contact-sub">Fill in the form and I will receive it directly in my email. I normally reply within 24 hours.</p>

      <form class="contact-form" action="https://formsubmit.co/paulaalonso.design@gmail.com" method="POST" novalidate>
        <input type="hidden" name="_subject" id="formSubject" value="New project enquiry from pauxdesign.com">
        <input type="hidden" name="_next" id="formNext" value="">

        <div class="contact-grid">
          <div class="contact-field">
            <label for="name">Name</label>
            <input id="name" name="Name" type="text" required>
          </div>
          <div class="contact-field">
            <label for="email">Email</label>
            <input id="email" name="Email" type="email" required>
          </div>
        </div>

        <div class="contact-grid">
          <div class="contact-field">
            <label for="company">Company</label>
            <input id="company" name="Company" type="text">
          </div>
          <div class="contact-field">
            <label for="service">Service</label>
            <select id="service" name="Service">
              <option value="General enquiry">General enquiry</option>
              <option value="UX Audit">UX Audit</option>
              <option value="Product Design">Product Design</option>
              <option value="Web Design">Web Design</option>
            </select>
          </div>
        </div>

        <div class="contact-field">
          <label for="message">Project details</label>
          <textarea id="message" name="Message" placeholder="What are you building and what do you need help with?" required></textarea>
        </div>

        <div class="contact-error" id="contactError" role="alert" aria-live="polite"></div>

        <p class="contact-recaptcha-note">After you send, FormSubmit may show a quick Google reCAPTCHA check before your message is delivered.</p>

        <div class="contact-actions">
          <button type="submit" class="btn btn-dark" id="contactSubmit">Send enquiry</button>
        </div>
      </form>
    </div>
  </div>
</main>

<footer>
  <div class="footer-inner">
    <div class="footer-brand">
      <a href="/"><img src="/Public/Images/logo.png" alt="Paux Design"></a>
      <p class="footer-brand-name">PAUX Design</p>
      <p class="footer-brand-tagline">Product Designer for high-growth startups &amp; digital products. London · Remote.</p>
    </div>
    <div class="footer-sitemap">
      <div class="footer-sitemap-label">Site map</div>
      <div class="footer-sitemap-grid">
        <a href="/#about">About</a>
        <a href="/work/">Work</a>
        <a href="/#services">Services</a>
        <a href="/#faq">FAQ</a>
        <a href="/#process">Process</a>
        <a href="/contact/">Contact</a>
        <a href="/work/enterprise-saas/">Enterprise SaaS</a>
        <a href="/work/mila-ai/">Mila AI</a>
        <a href="/work/joblink/">JobLink</a>
      </div>
    </div>
    <div class="footer-right">
      <div class="footer-social-links">
        <a class="footer-social-link" href="https://www.linkedin.com/in/paula-alonso-design/" target="_blank" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
        </a>
        <a class="footer-social-link" href="https://www.instagram.com/pauxdesign/" target="_blank" aria-label="Instagram">
          <svg viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </a>
      </div>
    </div>
  </div>
  <div class="footer-bottom">
    <div class="footer-copy">© 2026 Paula Alonso · Paux Design</div>
    <div class="footer-rights">All rights reserved</div>
  </div>
</footer>

<script>
function toggleMobileNav() {
  const btn = document.getElementById('navHamburger');
  const overlay = document.getElementById('navMobileOverlay');
  const isOpen = overlay.classList.contains('open');
  btn.classList.toggle('open', !isOpen);
  overlay.classList.toggle('open', !isOpen);
  btn.setAttribute('aria-expanded', !isOpen ? 'true' : 'false');
  document.body.style.overflow = isOpen ? '' : 'hidden';
}

function closeMobileNav() {
  const btn = document.getElementById('navHamburger');
  btn.classList.remove('open');
  btn.setAttribute('aria-expanded', 'false');
  document.getElementById('navMobileOverlay').classList.remove('open');
  document.body.style.overflow = '';
}

(() => {
  const topicMap = {
    'ux-audit': 'UX Audit',
    'product-design': 'Product Design',
    'web-design': 'Web Design',
    'project-enquiry': 'General enquiry',
    'start-project': 'General enquiry'
  };

  const subjectMap = {
    'ux-audit': 'UX Audit enquiry',
    'product-design': 'Product Design enquiry',
    'web-design': 'Web Design enquiry',
    'project-enquiry': 'Project enquiry',
    'start-project': 'Start a project enquiry'
  };

  const params = new URLSearchParams(window.location.search);
  const topic = params.get('topic');
  const service = document.getElementById('service');
  const subject = document.getElementById('formSubject');
  const form = document.querySelector('.contact-form');
  const emailInput = document.getElementById('email');
  const errorBox = document.getElementById('contactError');
  const nextField = document.getElementById('formNext');

  function showError(message) {
    errorBox.textContent = message;
    errorBox.classList.add('show');
  }

  function clearError() {
    errorBox.classList.remove('show');
    errorBox.textContent = '';
  }

  if (topic && topicMap[topic]) {
    service.value = topicMap[topic];
    subject.value = subjectMap[topic] || 'New project enquiry from pauxdesign.com';
  }

  if (nextField) {
    try {
      nextField.value = new URL('/thank-you/', window.location.href).href;
    } catch (e) {
      nextField.value = '';
    }
  }

  if (form && emailInput && errorBox) {
    const validateEmail = (event) => {
      const value = emailInput.value.trim();
      const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/;

      if (!value) {
        event.preventDefault();
        showError('Please enter your email before sending.');
        emailInput.focus();
        return false;
      }

      if (!emailPattern.test(value)) {
        event.preventDefault();
        showError('Please enter a valid email address (example@domain.com).');
        emailInput.focus();
        return false;
      }

      clearError();
      return true;
    };

    form.addEventListener('submit', validateEmail);
    emailInput.addEventListener('input', () => {
      if (errorBox.classList.contains('show')) clearError();
    });
  }
})();
</script>
</body>
</html>
