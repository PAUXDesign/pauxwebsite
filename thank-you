<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" href="/Public/Images/icon.png" type="image/png">
<title>Thank You — Paux Design</title>
<link href="https://fonts.googleapis.com/css2?family=Merriweather:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&family=Manrope:wght@300;400;500;600;700&family=Hanken+Grotesk:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/styles.css">
<style>
.thanks-page {
  min-height: 100vh;
  padding: 140px 20px 80px;
  background: var(--bg);
  display: flex;
  align-items: center;
  justify-content: center;
}
.thanks-card {
  width: min(760px, 100%);
  background: #fff;
  border: 1px solid var(--border);
  border-radius: 24px;
  box-shadow: 0 16px 40px rgba(190,195,230,0.55);
  padding: 56px 42px;
  text-align: center;
  position: relative;
  isolation: isolate;
}
.thanks-card::before {
  content: '';
  position: absolute;
  inset: 10px;
  border-radius: 16px;
  background: rgba(255, 255, 255, 0.62);
  border: 1px solid rgba(38, 30, 72, 0.05);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  box-shadow: 0 8px 20px rgba(38, 30, 72, 0.08);
  z-index: 0;
}
.thanks-card > * {
  position: relative;
  z-index: 1;
}
.thanks-kicker {
  font-family: var(--font-meta);
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--accent);
  margin-bottom: 14px;
}
.thanks-title {
  font-family: var(--font-serif);
  font-size: clamp(30px, 4vw, 44px);
  line-height: 1.15;
  color: var(--dark);
  margin-bottom: 12px;
}
.thanks-text {
  color: var(--mid);
  font-size: 14px;
  line-height: 1.7;
  max-width: 540px;
  margin: 0 auto 28px;
}
.thanks-card .btn {
  width: auto;
  max-width: fit-content;
  padding-left: 24px;
  padding-right: 24px;
}
@media (max-width: 700px) {
  .thanks-card { padding: 34px 22px; border-radius: 18px; }
  .thanks-card::before { inset: 8px; border-radius: 12px; }
  .thanks-card .btn {
    width: auto;
    max-width: fit-content;
    margin-left: auto;
    margin-right: auto;
  }
}
</style>
</head>
<body>
<main class="thanks-page">
  <section class="thanks-card">
    <div class="thanks-kicker">Message sent</div>
    <h1 class="thanks-title">Thank you, I got your message.</h1>
    <p class="thanks-text">I will review your enquiry and reply within 24 hours with the next steps.</p>
    <a href="/" class="btn btn-dark">Back to home</a>
  </section>
</main>

<footer>
  <div class="footer-inner">
    <div class="footer-brand">
      <a href="/"><img src="/Public/Images/logo.png" alt="Paux Design"></a>
      <p class="footer-brand-name">PAUX Design</p>
      <p class="footer-brand-tagline">Product Designer for high-growth startups &amp; digital products. London · Remote.</p>
    </div>
    <div class="footer-sitemap">
      <div class="footer-sitemap-label">Site map</div>
      <div class="footer-sitemap-grid">
        <a href="/#about">About</a>
        <a href="/work/">Work</a>
        <a href="/#services">Services</a>
        <a href="/#faq">FAQ</a>
        <a href="/#process">Process</a>
        <a href="/contact/">Contact</a>
        <a href="/work/enterprise-saas/">Enterprise SaaS</a>
        <a href="/work/mila-ai/">Mila AI</a>
        <a href="/work/joblink/">JobLink</a>
      </div>
    </div>
    <div class="footer-right">
      <div class="footer-social-links">
        <a class="footer-social-link" href="https://www.linkedin.com/in/paula-alonso-design/" target="_blank" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
        </a>
        <a class="footer-social-link" href="https://www.instagram.com/pauxdesign/" target="_blank" aria-label="Instagram">
          <svg viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </a>
      </div>
    </div>
  </div>
  <div class="footer-bottom">
    <div class="footer-copy">© 2026 Paula Alonso · Paux Design</div>
    <div class="footer-rights">All rights reserved</div>
  </div>
</footer>
</body>
</html>
